---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About | Combat Dietitian" description="Meet the dietitian behind Combat Dietitian — USAF Pararescue and professional UFC nutrition experience. Board-certified sports dietitian (CSSD).">
  <Nav />

  <section class="pt-40 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">About</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-black tracking-tight">
        The Dietitian Behind the <span class="text-accent-500">Mission</span>
      </h1>

      <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Photo placeholder -->
        <div class="bg-brand-800/60 border border-white/10 rounded-2xl overflow-hidden min-h-[300px]">
          <img src="/headshot.webp" alt="Combat Dietitian" class="w-full h-full object-cover" />
        </div>

        <!-- Bio -->
        <div class="lg:col-span-2 space-y-5 text-white/70 leading-relaxed">
          <p>
            Combat Dietitian is the nutrition consulting arm of <strong class="text-white">Marques Performance Systems, LLC</strong>. As a <a href="/tactical-dietitian" class="text-accent-400 hover:text-accent-300 underline">tactical and performance dietitian</a>, I specialize in working with military special operators, law enforcement, first responders, and combat sport athletes who need nutrition strategies that hold up under real-world pressure.
          </p>
          <p>
            My experience includes working with <strong class="text-white">USAF Pararescue (PJs)</strong> and special operations personnel — designing nutrition protocols for some of the most physically demanding roles in the military. I've also worked with professional UFC fighters and weight-class athletes, managing weight cuts, fight camp nutrition, and competition-day fueling at the highest level.
          </p>
          <p>
            That combination of tactical and combat sports experience means I understand what it takes to fuel performance in high-stress, unpredictable environments — whether you're on a mission, in a cage, or making weight.
          </p>
          <p>
            I built Calsanova because existing nutrition tools weren't designed for the athletes I serve. Tactical operators don't eat on a 9-to-5 schedule. Fighters cutting weight need precision, not generic calorie targets. Our AI-powered platform adapts to the real demands of your training and competition cycle.
          </p>

          <div class="pt-4 border-t border-white/10">
            <h3 class="text-white font-bold text-lg mb-3">Credentials & Affiliations</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <span class="text-accent-500">&check;</span>
                Registered Dietitian (RD)
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent-500">&check;</span>
                Board Certified Specialist in Sports Dietetics (CSSD)
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 px-4 bg-brand-800/30">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">How We Operate</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { title: 'Evidence First', description: 'Every recommendation is backed by peer-reviewed research. No fads, no bro-science.' },
          { title: 'Mission-Specific', description: "We don't do cookie-cutter plans. Your nutrition strategy is built for your exact operational demands." },
          { title: 'Tech-Enhanced', description: 'AI handles the tracking and analysis so we can focus on what matters — your performance.' },
        ].map(v => (
          <div class="text-center">
            <h3 class="text-xl font-bold mb-3">{v.title}</h3>
            <p class="text-white/60 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
