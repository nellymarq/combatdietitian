---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About | Combat Dietitian">
  <Nav />

  <section class="pt-32 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">About</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-black tracking-tight">
        The Dietitian Behind the <span class="text-accent-500">Mission</span>
      </h1>

      <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Photo placeholder -->
        <div class="bg-brand-800/60 border border-white/10 rounded-2xl flex items-center justify-center min-h-[300px]">
          <div class="text-center text-white/30">
            <div class="text-5xl mb-3">&#128100;</div>
            <p class="text-sm">Your Photo Here</p>
          </div>
        </div>

        <!-- Bio -->
        <div class="lg:col-span-2 space-y-5 text-white/70 leading-relaxed">
          <p>
            Combat Dietitian is the nutrition consulting arm of <strong class="text-white">Marques Performance Systems, LLC</strong>. We specialize in working with tactical athletes, combat sport competitors, and high performers who need nutrition strategies that hold up under real-world pressure.
          </p>
          <p>
            Our approach combines evidence-based sports nutrition with proprietary AI technology. Every client gets hands-on coaching from a qualified dietitian <em>and</em> access to Calsanova — our AI-powered nutrition platform built specifically for the demands of high-performance athletes.
          </p>
          <p>
            We built Calsanova because existing nutrition tools weren't designed for the athletes we serve. Tactical operators don't eat on a 9-to-5 schedule. Fighters cutting weight need precision, not generic calorie targets. Our platform adapts to the real demands of your training and competition cycle.
          </p>

          <div class="pt-4 border-t border-white/10">
            <h3 class="text-white font-bold text-lg mb-3">Credentials & Affiliations</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <span class="text-accent-500">&check;</span>
                Registered Dietitian (RD)
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent-500">&check;</span>
                Board Certified Specialist in Sports Dietetics (CSSD)
              </li>
              <li class="flex items-center gap-2">
                <span class="text-accent-500">&check;</span>
                <!-- Add your real credentials here -->
                Additional credentials coming soon
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 px-4 bg-brand-800/30">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">How We Operate</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { title: 'Evidence First', description: 'Every recommendation is backed by peer-reviewed research. No fads, no bro-science.' },
          { title: 'Mission-Specific', description: "We don't do cookie-cutter plans. Your nutrition strategy is built for your exact operational demands." },
          { title: 'Tech-Enhanced', description: 'AI handles the tracking and analysis so we can focus on what matters — your performance.' },
        ].map(v => (
          <div class="text-center">
            <h3 class="text-xl font-bold mb-3">{v.title}</h3>
            <p class="text-white/60 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
