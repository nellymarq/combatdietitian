---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: '&#9876;',
    title: 'Tactical Nutrition',
    description: 'Periodized nutrition plans for military, law enforcement, and first responders operating in high-stress, unpredictable environments.',
    href: '/tactical-dietitian',
  },
  {
    icon: '&#9889;',
    title: 'Combat Sports & Weight Class Athletes',
    description: 'Weight cuts, fight camp fueling, and recovery protocols for UFC/MMA, boxing, wrestling, and BJJ athletes. Proven at the professional level.',
  },
  {
    icon: '&#9881;',
    title: 'AI-Powered Tracking',
    description: 'Every client gets access to Calsanova — our proprietary platform with photo-based food logging, AI meal plans, and real-time analytics.',
  },
];

const stats = [
  { value: '500+', label: 'Athletes Served' },
  { value: '24/7', label: 'AI Support' },
];
---

<Layout title="Combat Dietitian | Marques Performance Systems" description="Elite nutrition for fighters, tactical operators, and weight-class athletes. UFC-proven protocols powered by Calsanova AI. Book a consultation.">
  <Nav />

  <Hero
    title='Fuel the <span class="text-accent-500">Fight.</span><br />Own the <span class="text-accent-500">Performance.</span>'
    subtitle="Tactical and performance dietitian with USAF Pararescue and professional UFC experience. Elite nutrition consulting for special operators, fighters, and weight-class athletes — backed by science, powered by AI."
    cta={{ label: 'Book a Consultation', href: '/contact' }}
    secondaryCta={{ label: 'Explore Calsanova', href: '/calsanova' }}
    bgImage="/hero-bg.png"
  />

  <!-- Stats bar -->
  <section class="bg-brand-800/50 border-y border-white/5">
    <div class="max-w-5xl mx-auto px-4 py-10 grid grid-cols-2 gap-4 text-center">
      {stats.map(stat => (
        <div>
          <div class="text-3xl sm:text-4xl font-black text-accent-500">{stat.value}</div>
          <div class="text-sm text-white/50 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Services preview -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="What We Do"
        title="Performance Nutrition, Reimagined"
        subtitle="We combine hands-on dietitian expertise with cutting-edge AI to deliver results that traditional consulting can't match."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map(service => (
          service.href ? (
            <a href={service.href} class="block bg-brand-800/40 border border-white/5 rounded-xl p-8 hover:border-accent-500/30 transition-colors">
              <div class="text-3xl mb-4" set:html={service.icon} />
              <h3 class="text-xl font-bold mb-3">{service.title}</h3>
              <p class="text-white/60 leading-relaxed">{service.description}</p>
            </a>
          ) : (
            <div class="bg-brand-800/40 border border-white/5 rounded-xl p-8 hover:border-accent-500/30 transition-colors">
              <div class="text-3xl mb-4" set:html={service.icon} />
              <h3 class="text-xl font-bold mb-3">{service.title}</h3>
              <p class="text-white/60 leading-relaxed">{service.description}</p>
            </div>
          )
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="text-accent-400 hover:text-accent-500 font-medium transition-colors">
          View All Services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Calsanova teaser -->
  <section class="py-20 px-4 bg-brand-800/30">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">Our Technology</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight">
          Meet <span class="text-gold-400">Calsanova</span>
        </h2>
        <p class="mt-4 text-white/60 text-lg leading-relaxed">
          Every MPS client gets access to our proprietary AI nutrition platform. Snap a photo of your meal for instant macro analysis. Get personalized meal plans that adapt to your training schedule. Track everything in one place.
        </p>
        <ul class="mt-6 space-y-3">
          {['AI-powered food recognition', 'Adaptive meal planning', 'Live video consultations', 'Wearable integrations'].map(item => (
            <li class="flex items-center gap-3 text-white/70">
              <span class="text-accent-500 text-lg">&check;</span>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="/calsanova"
          class="inline-block mt-8 bg-gold-500 hover:bg-gold-400 text-brand-900 font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Learn More About Calsanova
        </a>
      </div>
      <div class="bg-brand-800/60 border border-white/10 rounded-2xl overflow-hidden">
        <img src="/athlete-dashboard.jpg" alt="Calsanova athlete dashboard" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- Scythene teaser -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="lg:order-2">
        <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">Our Supplements</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight">
          Meet <span class="text-gold-400">Scythene</span>
        </h2>
        <p class="mt-4 text-white/60 text-lg leading-relaxed">
          Third-party tested supplements built for athletes and operators who don't have time for guesswork. No proprietary blends. No filler. Every ingredient at its evidence-based dose — the same standards we apply to every protocol at Combat Dietitian.
        </p>
        <ul class="mt-6 space-y-3">
          {['Evidence-based dosing', 'Third-party tested', 'No proprietary blends', 'Built for combat & tactical athletes'].map(item => (
            <li class="flex items-center gap-3 text-white/70">
              <span class="text-accent-500 text-lg">&check;</span>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="/scythene"
          class="inline-block mt-8 bg-gold-500 hover:bg-gold-400 text-brand-900 font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Learn More About Scythene
        </a>
      </div>
      <div class="bg-brand-800/60 border border-white/10 rounded-2xl overflow-hidden lg:order-1 flex items-center justify-center p-12">
        <div class="text-center">
          <span class="text-5xl font-black tracking-tight text-white">SCYTHENE</span>
          <p class="text-white/40 text-sm mt-2 uppercase tracking-widest">Supplements</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who I've Worked With -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="Experience"
        title="Trusted by Operators & Athletes"
      />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center">
        {[
          { name: 'USAF Pararescue', detail: 'Special Operations' },
          { name: 'Professional UFC', detail: 'Fight Camp Nutrition' },
          { name: 'SEC Athletics', detail: 'Collegiate Performance' },
          { name: 'Law Enforcement', detail: 'Tactical Units' },
        ].map(org => (
          <div class="text-center p-6 bg-brand-800/40 border border-white/5 rounded-xl">
            <h3 class="text-white font-bold">{org.name}</h3>
            <p class="text-white/40 text-sm mt-1">{org.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 px-4 bg-brand-800/30">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="Results"
        title="What Clients Say"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            quote: 'The precision of the weight cut protocol was unlike anything I had before. Made weight comfortably and felt strong on fight night.',
            name: 'Professional MMA Fighter',
            context: 'UFC Athlete',
          },
          {
            quote: 'Understanding how to fuel around unpredictable mission schedules changed the game for me and my team.',
            name: 'USAF Operator',
            context: 'Special Operations',
          },
          {
            quote: 'Calsanova makes it effortless to stay on track. The AI meal plans adapt to my training load automatically.',
            name: 'D1 Athlete',
            context: 'Collegiate Football',
          },
        ].map(t => (
          <div class="bg-brand-800/40 border border-white/5 rounded-xl p-8">
            <p class="text-white/70 leading-relaxed italic">&ldquo;{t.quote}&rdquo;</p>
            <div class="mt-6 pt-4 border-t border-white/5">
              <p class="text-white font-semibold text-sm">{t.name}</p>
              <p class="text-white/40 text-xs">{t.context}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="Nationwide"
        title="Serving Athletes & Operators Everywhere"
      />
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { city: 'Miami', href: '/locations/miami/sports-dietitian' },
          { city: 'Las Vegas', href: '/locations/las-vegas/sports-dietitian' },
          { city: 'New York', href: '/locations/new-york/sports-dietitian' },
          { city: 'Orlando', href: '/locations/orlando/sports-dietitian' },
          { city: 'Melbourne, FL', href: '/locations/melbourne-fl/sports-dietitian' },
        ].map(loc => (
          <a href={loc.href} class="bg-brand-800/40 border border-white/5 rounded-lg px-6 py-3 hover:border-accent-500/30 transition-colors">
            <span class="text-white font-semibold text-sm">{loc.city}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold">Ready to Optimize Your Nutrition?</h2>
      <p class="mt-4 text-white/60 text-lg">
        Whether you're a tactical operator, combat athlete, or high performer — we'll build a plan that fits your mission.
      </p>
      <a
        href="/contact"
        class="inline-block mt-8 bg-accent-500 hover:bg-accent-600 text-white font-semibold px-8 py-3.5 rounded-lg text-lg transition-colors"
      >
        Get Started
      </a>
    </div>
  </section>

  <Footer />
</Layout>
