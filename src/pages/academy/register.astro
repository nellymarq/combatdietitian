---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AuthForm from '../../components/academy/AuthForm';
import { getUser } from '../../lib/supabase/server';

const user = await getUser(Astro.cookies);
if (user) return Astro.redirect('/academy/dashboard');
---

<Layout title="Create Account | CD Academy">
  <Nav />
  <section class="pt-32 pb-20 px-4">
    <div class="max-w-md mx-auto">
      <div class="text-center mb-10">
        <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">CD Academy</span>
        <h1 class="mt-3 text-3xl font-bold">Create Your Account</h1>
        <p class="mt-2 text-white/50">Sign up to enroll in the certification course.</p>
      </div>
      <AuthForm client:load mode="register" />
    </div>
  </section>
  <Footer />
</Layout>
