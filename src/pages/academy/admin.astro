---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getUser } from '../../lib/supabase/server';
import { createClient } from '@supabase/supabase-js';
import { FOUNDATION as COURSE } from '../../data/course';

const user = await getUser(Astro.cookies);
if (!user) return Astro.redirect('/academy/login');
if (user.email !== import.meta.env.ADMIN_EMAIL) return Astro.redirect('/academy/dashboard');

const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

// Get all enrollments with user info
const { data: enrollments } = await supabaseAdmin
  .from('enrollments')
  .select('*')
  .order('enrolled_at', { ascending: false });

// Get all progress
const { data: allProgress } = await supabaseAdmin
  .from('module_progress')
  .select('*');

// Get pending submissions
const { data: submissions } = await supabaseAdmin
  .from('assessment_submissions')
  .select('*')
  .order('submitted_at', { ascending: false });

// Get user details
const { data: { users } } = await supabaseAdmin.auth.admin.listUsers();
const userMap = new Map(users?.map(u => [u.id, u]) || []);

// Build student data
const students = (enrollments || []).map(e => {
  const u = userMap.get(e.user_id);
  const studentProgress = (allProgress || []).filter(p => p.user_id === e.user_id);
  const completedModules = studentProgress.filter(p => p.completed_at).length;
  const sub = (submissions || []).find(s => s.user_id === e.user_id);
  return {
    ...e,
    email: u?.email || 'Unknown',
    name: u?.user_metadata?.full_name || u?.email?.split('@')[0] || 'Unknown',
    completedModules,
    totalModules: COURSE.modules.length,
    progressPct: Math.round((completedModules / COURSE.modules.length) * 100),
    submission: sub,
  };
});

const pendingSubs = (submissions || []).filter(s => !s.reviewed_at);
const totalRevenue = (enrollments || []).reduce((sum, e) => sum + (e.price_paid_cents || 0), 0);
const failedProvisions = (enrollments || []).filter(e => e.calsanova_provisioned === false);
---

<Layout title="Admin | CD Academy">
  <Nav />
  <section class="pt-36 pb-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="mb-8">
        <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">Admin Dashboard</span>
        <h1 class="mt-1 text-3xl font-bold">CD Academy</h1>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-brand-800/40 border border-white/5 rounded-xl p-5">
          <div class="text-2xl font-bold text-accent-500">{enrollments?.length || 0}</div>
          <div class="text-white/40 text-sm">Enrolled Students</div>
        </div>
        <div class="bg-brand-800/40 border border-white/5 rounded-xl p-5">
          <div class="text-2xl font-bold text-gold-400">{pendingSubs.length}</div>
          <div class="text-white/40 text-sm">Pending Reviews</div>
        </div>
        <div class="bg-brand-800/40 border border-white/5 rounded-xl p-5">
          <div class="text-2xl font-bold text-green-400">{(enrollments || []).filter(e => e.completed_at).length}</div>
          <div class="text-white/40 text-sm">Completed</div>
        </div>
        <div class="bg-brand-800/40 border border-white/5 rounded-xl p-5">
          <div class="text-2xl font-bold text-white">${(totalRevenue / 100).toFixed(0)}</div>
          <div class="text-white/40 text-sm">Total Revenue</div>
        </div>
      </div>

      <!-- Failed Calsanova Provisions -->
      {failedProvisions.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-bold mb-4 text-red-400">Failed Calsanova Provisions</h2>
          <div class="space-y-3">
            {failedProvisions.map(e => {
              const student = students.find(s => s.user_id === e.user_id);
              return (
                <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 flex items-center justify-between">
                  <div>
                    <p class="font-medium">{student?.name || 'Unknown'}</p>
                    <p class="text-white/40 text-sm">{student?.email} — Enrolled {new Date(e.enrolled_at).toLocaleDateString()}</p>
                  </div>
                  <form method="POST" action="/api/admin/retry-provision">
                    <input type="hidden" name="enrollment_id" value={e.id} />
                    <button
                      type="submit"
                      class="bg-accent-500 hover:bg-accent-600 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors"
                    >
                      Retry
                    </button>
                  </form>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <!-- Pending Assessments -->
      {pendingSubs.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-bold mb-4">Pending Assessments</h2>
          <div class="space-y-4">
            {pendingSubs.map(sub => {
              const student = students.find(s => s.user_id === sub.user_id);
              return (
                <div class="bg-brand-800/40 border border-gold-500/30 rounded-xl p-6">
                  <div class="flex items-center justify-between mb-3">
                    <div>
                      <p class="font-semibold">{student?.name}</p>
                      <p class="text-white/40 text-sm">{student?.email} — Submitted {new Date(sub.submitted_at).toLocaleDateString()}</p>
                    </div>
                  </div>
                  <div class="bg-brand-900/50 rounded-lg p-4 max-h-60 overflow-y-auto">
                    <p class="text-white/70 text-sm whitespace-pre-wrap">{sub.content}</p>
                  </div>
                  <form method="POST" action={`/api/admin/review`} class="mt-4 flex items-end gap-4">
                    <input type="hidden" name="submission_id" value={sub.id} />
                    <input type="hidden" name="user_id" value={sub.user_id} />
                    <div class="flex-1">
                      <label class="block text-white/60 text-xs mb-1">Reviewer Notes</label>
                      <input
                        type="text"
                        name="notes"
                        class="w-full bg-brand-800/60 border border-white/10 rounded-lg px-3 py-2 text-white text-sm"
                        placeholder="Optional feedback for the student"
                      />
                    </div>
                    <button
                      type="submit"
                      name="action"
                      value="pass"
                      class="bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors"
                    >
                      Pass
                    </button>
                    <button
                      type="submit"
                      name="action"
                      value="fail"
                      class="bg-red-600 hover:bg-red-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors"
                    >
                      Fail
                    </button>
                  </form>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <!-- All Students -->
      <h2 class="text-xl font-bold mb-4">All Students</h2>
      <div class="bg-brand-800/40 border border-white/5 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/5">
              <th class="text-left p-4 text-white/40 font-medium">Student</th>
              <th class="text-left p-4 text-white/40 font-medium">Enrolled</th>
              <th class="text-left p-4 text-white/40 font-medium">Progress</th>
              <th class="text-left p-4 text-white/40 font-medium">Status</th>
            </tr>
          </thead>
          <tbody>
            {students.map(s => (
              <tr class="border-b border-white/5">
                <td class="p-4">
                  <p class="font-medium">{s.name}</p>
                  <p class="text-white/40 text-xs">{s.email}</p>
                </td>
                <td class="p-4 text-white/50">{new Date(s.enrolled_at).toLocaleDateString()}</td>
                <td class="p-4">
                  <div class="flex items-center gap-2">
                    <div class="w-20 bg-brand-700/50 rounded-full h-2">
                      <div class="bg-accent-500 h-2 rounded-full" style={`width: ${s.progressPct}%`}></div>
                    </div>
                    <span class="text-white/50 text-xs">{s.completedModules}/{s.totalModules}</span>
                  </div>
                </td>
                <td class="p-4">
                  {s.submission?.passed ? (
                    <span class="text-green-400 text-xs font-medium">Certified</span>
                  ) : s.submission?.submitted_at ? (
                    <span class="text-gold-400 text-xs font-medium">Assessment Submitted</span>
                  ) : s.progressPct === 100 ? (
                    <span class="text-white/50 text-xs">Modules Complete</span>
                  ) : (
                    <span class="text-white/30 text-xs">In Progress</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
