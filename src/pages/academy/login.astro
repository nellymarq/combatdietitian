---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AuthForm from '../../components/academy/AuthForm';
import { getUser } from '../../lib/supabase/server';

const user = await getUser(Astro.cookies);
if (user) return Astro.redirect('/academy/dashboard');

const verified = Astro.url.searchParams.get('verified') === 'true';
---

<Layout title="Log In | CD Academy">
  <Nav />
  <section class="pt-32 pb-20 px-4">
    <div class="max-w-md mx-auto">
      {verified && (
        <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 mb-8 text-center">
          <p class="text-green-400 font-semibold">Email verified successfully!</p>
          <p class="text-white/50 text-sm mt-1">Log in below to access your account.</p>
        </div>
      )}
      <div class="text-center mb-10">
        <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">CD Academy</span>
        <h1 class="mt-3 text-3xl font-bold">Welcome Back</h1>
        <p class="mt-2 text-white/50">Log in to access your course.</p>
      </div>
      <AuthForm client:load mode="login" />
    </div>
  </section>
  <Footer />
</Layout>
