---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="The HPO Classroom | Combat Dietitian" description="Human Performance Optimization — evidence-based articles on nutrition for combat athletes, tactical operators, and high performers.">
  <Nav />

  <section class="pt-40 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">Human Performance Optimization</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-black tracking-tight">
        The HPO <span class="text-accent-500">Classroom</span>
      </h1>
      <p class="mt-4 text-white/60 text-lg max-w-2xl">
        Evidence-based articles on nutrition for combat athletes, tactical operators, and high performers.
      </p>

      <div class="mt-12 grid grid-cols-1 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block bg-brand-800/50 border border-white/10 rounded-2xl p-6 sm:p-8 hover:border-accent-500/40 transition-colors"
          >
            <div class="flex flex-wrap gap-2 mb-4">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs font-medium uppercase tracking-wider text-gold-500 bg-gold-500/10 px-2.5 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-xl sm:text-2xl font-bold tracking-tight group-hover:text-accent-500 transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-3 text-white/60 leading-relaxed">
              {post.data.description}
            </p>
            <div class="mt-4 flex items-center gap-4 text-sm text-white/40">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span>&middot;</span>
              <span>{post.data.author}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
