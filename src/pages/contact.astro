---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Combat Dietitian" description="Book a nutrition consultation with Combat Dietitian. Free discovery call for fighters, military operators, and tactical athletes. Response in 24 hrs.">
  <Nav />

  <section class="pt-40 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">Contact</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-black tracking-tight">
        Start Your <span class="text-accent-500">Consultation</span>
      </h1>
      <p class="mt-4 text-white/60 text-lg max-w-2xl">
        Fill out the form below and we'll reach out within 24 hours to schedule your initial assessment.
      </p>

      <div class="mt-12 grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <form
          class="lg:col-span-3 space-y-6"
          action="https://formspree.io/f/mqeyndyn"
          method="POST"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-white/80 mb-2">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-brand-800/60 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-accent-500 transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-white/80 mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-brand-800/60 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-accent-500 transition-colors"
                placeholder="you@email.com"
              />
            </div>
          </div>

          <div>
            <label for="type" class="block text-sm font-medium text-white/80 mb-2">I train for...</label>
            <select
              id="type"
              name="athlete_type"
              required
              class="w-full bg-brand-800/60 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-accent-500 transition-colors"
            >
              <option value="" disabled selected>Select your sport or profession</option>
              <option value="military">Military / Special Operations</option>
              <option value="law-enforcement">Law Enforcement</option>
              <option value="fire-ems">Fire / EMS</option>
              <option value="mma-boxing">MMA / Boxing</option>
              <option value="wrestling-bjj">Wrestling / BJJ</option>
              <option value="strength">Strength / Powerlifting</option>
              <option value="endurance">Endurance Athlete</option>
              <option value="team-sport">Team Sport Athlete</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="package" class="block text-sm font-medium text-white/80 mb-2">Interested In</label>
            <select
              id="package"
              name="package"
              class="w-full bg-brand-800/60 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-accent-500 transition-colors"
            >
              <option value="" disabled selected>Select a package (optional)</option>
              <option value="recon">Recon — One-time assessment</option>
              <option value="operator">Operator — Monthly coaching</option>
              <option value="command">Command — Team package</option>
              <option value="unsure">Not sure yet</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-white/80 mb-2">Tell Us About Your Goals</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full bg-brand-800/60 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-accent-500 transition-colors resize-none"
              placeholder="Current training, nutrition challenges, competition dates, etc."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3.5 rounded-lg text-lg transition-colors"
          >
            Submit Inquiry
          </button>
        </form>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-brand-800/40 border border-white/5 rounded-xl p-6">
            <h3 class="font-bold text-lg mb-4">What Happens Next</h3>
            <ol class="space-y-4 text-sm text-white/60">
              <li class="flex gap-3">
                <span class="text-accent-500 font-bold shrink-0">1.</span>
                We review your submission and reach out within 24 hours.
              </li>
              <li class="flex gap-3">
                <span class="text-accent-500 font-bold shrink-0">2.</span>
                Schedule a free 15-minute discovery call to discuss your needs.
              </li>
              <li class="flex gap-3">
                <span class="text-accent-500 font-bold shrink-0">3.</span>
                Begin your assessment and get immediate Calsanova platform access.
              </li>
            </ol>
          </div>

          <div class="bg-brand-800/40 border border-white/5 rounded-xl p-6">
            <h3 class="font-bold text-lg mb-4">Direct Contact</h3>
            <ul class="space-y-3 text-sm text-white/60">
              <li>
                <span class="text-white/40 text-xs uppercase tracking-wider">Email</span><br />
                <a href="mailto:thecombatdietitian@gmail.com" class="text-white/70 hover:text-white transition-colors">
                  thecombatdietitian@gmail.com
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
