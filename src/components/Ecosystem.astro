---
import SectionHeading from './SectionHeading.astro';

interface Props {
  /** Which brand page we're currently on — that one won't be a link */
  current?: 'combat-dietitian' | 'calsanova' | 'scythene';
}

const { current } = Astro.props;

const brands = [
  {
    id: 'combat-dietitian',
    name: 'Combat Dietitian',
    href: '/services',
    description: 'Evidence-based nutrition consulting for fighters and operators.',
    color: 'text-accent-500',
    border: 'hover:border-accent-500/30',
  },
  {
    id: 'calsanova',
    name: 'Calsanova',
    href: '/calsanova',
    description: 'AI-powered nutrition platform for tracking, planning, and analytics.',
    color: 'text-gold-400',
    border: 'hover:border-gold-500/30',
  },
  {
    id: 'scythene',
    name: 'Scythene',
    href: '/scythene',
    description: 'Third-party tested supplements at clinical doses.',
    color: 'text-white',
    border: 'hover:border-white/20',
  },
];
---

<section class="py-20 px-4 bg-brand-800/30">
  <div class="max-w-4xl mx-auto text-center">
    <SectionHeading
      label="The MPS Ecosystem"
      title="Nutrition Consulting + AI Platform + Supplements"
      subtitle="Everything under Marques Performance Systems — built to work together."
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
      {brands.map(brand => {
        const isCurrent = brand.id === current;
        return isCurrent ? (
          <div class="bg-brand-800/40 border border-accent-500/20 rounded-xl p-6">
            <h3 class:list={['text-lg font-bold', brand.color]}>{brand.name}</h3>
            <p class="text-white/50 text-sm mt-2">{brand.description}</p>
            <span class="inline-block mt-3 text-xs text-white/30">You are here</span>
          </div>
        ) : (
          <a href={brand.href} class:list={['bg-brand-800/40 border border-white/5 rounded-xl p-6 transition-colors', brand.border]}>
            <h3 class:list={['text-lg font-bold', brand.color]}>{brand.name}</h3>
            <p class="text-white/50 text-sm mt-2">{brand.description}</p>
          </a>
        );
      })}
    </div>
  </div>
</section>
