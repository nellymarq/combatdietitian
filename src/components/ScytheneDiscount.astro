<section class="bg-brand-800/50 border-t border-white/5">
  <div class="max-w-5xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4 text-center sm:text-left">
    <p class="text-sm">
      <span class="text-accent-500 font-bold">25% OFF Scythene</span>
      <span class="text-white/50"> — for Academy students &amp; Calsanova members</span>
    </p>
    <a href="/scythene" class="text-gold-400 hover:text-gold-500 text-sm font-medium transition-colors shrink-0">
      Learn more &rarr;
    </a>
  </div>
</section>
