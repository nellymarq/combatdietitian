---
const year = new Date().getFullYear();
---

<footer class="bg-brand-900 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <span class="text-xl font-bold tracking-tight">
          <span class="text-white">COMBAT</span><span class="text-accent-500">DIETITIAN</span>
        </span>
        <p class="mt-3 text-white/50 text-sm leading-relaxed">
          A service of Marques Performance Systems, LLC.<br />
          Elite nutrition consulting for tactical athletes, fighters, and high performers.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/services" class="text-sm text-white/50 hover:text-white transition-colors">Services</a></li>
          <li><a href="/calsanova" class="text-sm text-white/50 hover:text-white transition-colors">Calsanova Platform</a></li>
          <li><a href="/about" class="text-sm text-white/50 hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-white/50 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Connect</h4>
        <ul class="space-y-2">
          <li><a href="mailto:contact@combatdietitian.com" class="text-sm text-white/50 hover:text-white transition-colors">contact@combatdietitian.com</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-center text-white/30 text-xs">
      &copy; {year} Marques Performance Systems, LLC. All rights reserved.
    </div>
  </div>
</footer>
