---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
}

const { label, title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  {label && (
    <span class="text-accent-500 text-sm font-semibold uppercase tracking-widest">{label}</span>
  )}
  <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight">{title}</h2>
  {subtitle && (
    <p class="mt-4 text-white/60 max-w-2xl mx-auto text-lg">{subtitle}</p>
  )}
</div>
